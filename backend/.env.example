# Vultr Serverless Inference (OpenAI-compatible)
VULTR_API_KEY=your_vultr_api_key_here
VULTR_BASE_URL=https://api.vultrinference.com/v1
VULTR_EXECUTOR_MODEL=nvidia/Nemotron-Cascade-2-30B-A3B
VULTR_CRITIC_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16

# Optional: use cached responses for demo resilience
DEMO_CACHE_ENABLED=false

# CORS
FRONTEND_ORIGIN=http://localhost:3000
